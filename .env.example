# Copy to .env.local for local dev, or set in Vercel → Settings → Environment Variables.
# Create a free project at https://supabase.com, then run supabase/schema.sql in the SQL editor.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# In Supabase: Authentication → Providers → Email → disable "Confirm email"
# so sign-up returns a session immediately.
